{
  "lock": false,
  "tasks": {
    "test": "deno test --allow-net --allow-read --allow-run --allow-write=tests/__snapshots__ --reporter=dot",
    "update-deps": "deno run -A 'https://deno.land/x/nudd@v0.2.11/cli.ts' update deno.json mod.ts tests/deps.ts"
  },
  "lint": {
    "rules": {
      "exclude": ["no-import-prefix"]
    }
  },
  "fmt": {
    "exclude": [
      "CHANGELOG.md"
    ]
  }
}
